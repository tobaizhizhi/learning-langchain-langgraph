MODEL_ID=openai:你的模型
MODEL_BASE_URL=你的中转地址
OPENAI_API_KEY=你的中转key

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=你的_langsmith_key
LANGSMITH_PROJECT=aiframe-phase3

