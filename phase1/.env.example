# Default offline demo. This does not call any real model provider.
MODEL_ID=mock:mock-chat

# OpenAI official API example:
# MODEL_ID=openai:gpt-4o-mini
# OPENAI_API_KEY=sk-...

# OpenAI-compatible proxy example:
# MODEL_ID=openai:gpt-4o-mini
# MODEL_BASE_URL=https://your-proxy.example.com/v1
# OPENAI_API_KEY=your-proxy-key

# Optional model parameters:
# MODEL_TEMPERATURE=0
# MODEL_MAX_TOKENS=1000
# MODEL_TIMEOUT_MS=30000
# MODEL_MAX_RETRIES=2

# Optional prompt overrides for `pnpm phase1:invoke`:
# SYSTEM_PROMPT_NAME=study
# SYSTEM_PROMPT_NAME=solidity-security
# SYSTEM_PROMPT=你是一个严谨的 AI 工程学习助手。
# USER_PROMPT=请用三句话解释 Solidity 里的 reentrancy。

# Optional run log path. Use "off" to disable logging in the invoke demo.
# MODEL_RUN_LOG_PATH=phase1/runs/model-runs.jsonl
