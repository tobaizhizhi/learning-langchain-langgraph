# Local Ollama embeddings.
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_MAX_RETRIES=2
EMBEDDING_BATCH_SIZE=16

# OpenAI official API or OpenAI-compatible proxy alternative.
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=your-api-key
# EMBEDDING_BASE_URL=https://api.openai.com/v1

# Vector store, used from Step 6.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=aiframe_phase4
QDRANT_RESET_COLLECTION=false
QDRANT_INDEX_BATCH_SIZE=4

# Search CLI defaults, used from Step 7.
PHASE4_SEARCH_TOP_K=4
PHASE4_SEARCH_PREVIEW_CHARS=260

# RAG answer defaults, used from Step 8.
PHASE4_RAG_TOP_K=4
PHASE4_RAG_MAX_CHUNK_CHARS=1600

# Local JSON reports for Step 9. Set to "off" to disable.
PHASE4_RAG_REPORT_DIR=phase4/runs/rag

# RAG eval defaults, used from Step 10. Set report dir to "off" to disable.
PHASE4_EVAL_TOP_K=4
PHASE4_EVAL_MAX_CHUNK_CHARS=1600
PHASE4_EVAL_REPORT_DIR=phase4/runs/eval
# PHASE4_EVAL_CASE_LIMIT=3
